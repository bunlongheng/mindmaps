# ---- Client (Vite, VITE_ prefix is bundled into the browser) ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key            # public by design

# ---- Server (Vercel serverless functions in api/) ----
DATABASE_URL=postgres://user:pass@host:5432/db  # Postgres for map storage
DATABASE_CA_CERT=                               # PEM CA cert for TLS verify (blank = skip verify, dev only)
ANTHROPIC_API_KEY=sk-ant-...                    # Claude API key for AI generation
MINDMAP_AI_API_KEY=                             # bearer key for the external agent import API
MINDMAP_JWT_SECRET=                             # HMAC secret used to sign/verify session tokens
MINDMAP_AUTH_EMAIL=you@example.com              # login email
MINDMAP_AUTH_PASSWORD_HASH=                     # sha-256 hex of the login password (never the plaintext)
MINDMAP_USER_ID=                                # owner user id issued in the session token

# ---- Optional ----
SUPABASE_SERVICE_ROLE_KEY=                       # server-only; used by /api/notify realtime broadcast
